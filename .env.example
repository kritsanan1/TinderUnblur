# =============================================================================
# Tinder Optimizer - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update the values according to your environment
# 
# SECURITY NOTE: Never commit your actual .env file to version control!
# Add .env to your .gitignore file to prevent accidental exposure of secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Environment mode - affects logging, error handling, and optimizations
# Options: development, staging, production, test
NODE_ENV=development

# Port for the Express.js server to listen on
# Default: 5000 (must match Vite proxy configuration)
PORT=5000

# Base URL for API requests from the frontend
# Development: http://localhost:5000
# Production: https://your-domain.com
VITE_API_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# NOTE: The application uses in-memory storage by default for development.
# Uncomment and configure these variables to use PostgreSQL database.

# Complete database connection string
# Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://username:password@localhost:5432/tinder_optimizer

# Individual database connection parameters (alternative to DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=tinder_optimizer
# PGUSER=your_username
# PGPASSWORD=your_secure_password

# Database connection pool settings
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_CONNECTION_TIMEOUT=10000

# -----------------------------------------------------------------------------
# Tinder API Integration
# -----------------------------------------------------------------------------
# Official Tinder API configuration for real data integration
# These settings follow the official Tinder API documentation

# Tinder API base URL (official endpoint)
TINDER_API_BASE_URL=https://api.gotinder.com

# Tinder application version (required header)
# This should match the version used by the official Tinder web app
TINDER_APP_VERSION=1020343

# Platform identifier for API requests
# Options: web, android, ios
TINDER_PLATFORM=web

# Default locale for API requests
# Examples: en, es, fr, de, pt, it
TINDER_LOCALE=en

# Rate limiting configuration to prevent API abuse
# TINDER_RATE_LIMIT_PER_MINUTE=30
# TINDER_RATE_LIMIT_PER_HOUR=500

# User agent string for API requests (optional)
# TINDER_USER_AGENT=Mozilla/5.0 (compatible; TinderOptimizer/1.0)

# -----------------------------------------------------------------------------
# Authentication & Session Management
# -----------------------------------------------------------------------------

# Session secret for secure session cookies
# CRITICAL: Use a long, random string in production (min 64 characters)
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-change-this-in-production-use-64-chars-minimum

# Session configuration
SESSION_MAX_AGE=86400000
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# JWT settings (if implementing JWT authentication)
# JWT_SECRET=your-jwt-secret-key
# JWT_EXPIRES_IN=24h
# JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# External Services & Integrations
# -----------------------------------------------------------------------------

# Analytics service (if using external analytics)
# ANALYTICS_API_KEY=your-analytics-api-key
# ANALYTICS_ENDPOINT=https://api.analytics-service.com

# Email service configuration (for notifications)
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=your-email-service-api-key
# EMAIL_FROM=noreply@tinderoptimizer.app

# Cloud storage (for user data backup)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=tinder-optimizer-storage

# Redis configuration (for caching and sessions)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------

# CORS configuration
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
# CORS_CREDENTIALS=true

# Rate limiting settings
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# API key for internal service authentication
# API_SECRET_KEY=your-internal-api-secret

# Encryption key for sensitive data
# ENCRYPTION_KEY=your-encryption-key-32-characters

# -----------------------------------------------------------------------------
# Development & Debugging
# -----------------------------------------------------------------------------

# Debug mode for additional logging
# DEBUG=tinder-optimizer:*

# Log level configuration
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Enable request logging
# LOG_REQUESTS=true

# Enable API response caching
# ENABLE_CACHE=true
# CACHE_TTL=3600

# Mock data mode for development
# MOCK_TINDER_API=false
# MOCK_ANALYTICS=false

# -----------------------------------------------------------------------------
# Testing Configuration
# -----------------------------------------------------------------------------

# Test database (separate from development database)
# TEST_DATABASE_URL=postgresql://testuser:testpass@localhost:5432/tinder_optimizer_test

# Test environment settings
# TEST_TIMEOUT=10000
# TEST_COVERAGE_THRESHOLD=80

# Mock external services in tests
# TEST_MOCK_TINDER_API=true
# TEST_MOCK_EMAIL=true

# -----------------------------------------------------------------------------
# Production & Deployment
# -----------------------------------------------------------------------------

# Application name and version
# APP_NAME=Tinder Optimizer
# APP_VERSION=1.0.0

# Health check endpoint configuration
# HEALTH_CHECK_ENDPOINT=/health
# HEALTH_CHECK_TIMEOUT=5000

# SSL/TLS configuration (production only)
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_KEY_PATH=/path/to/private.key

# Content Security Policy
# CSP_ENABLED=true
# CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline'"

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------

# Application monitoring
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=development

# Performance monitoring
# NEW_RELIC_LICENSE_KEY=your-new-relic-key
# NEW_RELIC_APP_NAME=Tinder Optimizer

# Metrics collection
# METRICS_ENABLED=true
# METRICS_PORT=9090

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable/disable specific features
# FEATURE_AUTO_SWIPE=true
# FEATURE_TEASER_UNBLUR=true
# FEATURE_ADVANCED_ANALYTICS=true
# FEATURE_PROFILE_OPTIMIZATION=true

# Beta features
# FEATURE_AI_SUGGESTIONS=false
# FEATURE_BULK_OPERATIONS=false

# =============================================================================
# Configuration Examples by Environment
# =============================================================================

# DEVELOPMENT EXAMPLE:
# NODE_ENV=development
# PORT=5000
# VITE_API_URL=http://localhost:5000
# SESSION_SECRET=dev-secret-change-in-production
# LOG_LEVEL=debug
# MOCK_TINDER_API=true

# STAGING EXAMPLE:
# NODE_ENV=staging
# PORT=5000
# VITE_API_URL=https://staging.tinderoptimizer.app
# DATABASE_URL=postgresql://user:pass@staging-db:5432/tinder_optimizer
# SESSION_SECRET=staging-session-secret-64-chars-minimum
# LOG_LEVEL=info
# TINDER_RATE_LIMIT_PER_MINUTE=20

# PRODUCTION EXAMPLE:
# NODE_ENV=production
# PORT=5000
# VITE_API_URL=https://tinderoptimizer.app
# DATABASE_URL=postgresql://user:pass@prod-db:5432/tinder_optimizer
# SESSION_SECRET=production-session-secret-must-be-very-secure-64-chars
# LOG_LEVEL=warn
# TINDER_RATE_LIMIT_PER_MINUTE=30
# SSL_CERT_PATH=/etc/ssl/certs/certificate.crt
# SSL_KEY_PATH=/etc/ssl/private/private.key

# =============================================================================
# Security Checklist
# =============================================================================

# ✅ Change all default passwords and secrets
# ✅ Use strong, unique SESSION_SECRET (minimum 64 characters)
# ✅ Never commit .env file to version control
# ✅ Use environment-specific configurations
# ✅ Enable SSL/TLS in production
# ✅ Configure proper CORS origins
# ✅ Set appropriate rate limits
# ✅ Use secure session settings
# ✅ Enable security headers in production
# ✅ Configure proper error handling and logging